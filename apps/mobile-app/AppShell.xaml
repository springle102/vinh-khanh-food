<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="VinhKhanh.MobileApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanh.MobileApp"
    FlyoutBehavior="Disabled"
    Title="VinhKhanhFoodGuide">

    <ShellContent
        Route="SplashPage"
        ContentTemplate="{DataTemplate local:SplashPage}" />

    <ShellContent
        Route="LanguageSelectionPage"
        ContentTemplate="{DataTemplate local:LanguageSelectionPage}" />

    <TabBar Route="MainTabs" Shell.TabBarIsVisible="False">
        <ShellContent Route="HomePage" ContentTemplate="{DataTemplate local:HomePage}" />
        <ShellContent Route="MapPage" ContentTemplate="{DataTemplate local:MapPage}" />
        <ShellContent Route="PoiListPage" ContentTemplate="{DataTemplate local:PoiListPage}" />
        <ShellContent Route="QrScannerPage" ContentTemplate="{DataTemplate local:QrScannerPage}" />
        <ShellContent Route="SettingsPage" ContentTemplate="{DataTemplate local:SettingsPage}" />
    </TabBar>
</Shell>
