<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="BrandOrange">#FF5A0A</Color>
    <Color x:Key="BrandOrangeSoft">#FFF2E8</Color>
    <Color x:Key="BrandOrangePale">#FFF8F3</Color>
    <Color x:Key="BrandInk">#102545</Color>
    <Color x:Key="BrandInkSoft">#5E6D86</Color>
    <Color x:Key="BrandMuted">#9CA6B8</Color>
    <Color x:Key="BrandStroke">#E7EBF2</Color>
    <Color x:Key="BrandCanvas">#F5F7FB</Color>
    <Color x:Key="BrandWhite">#FFFFFF</Color>
    <Color x:Key="BrandNavy">#151F33</Color>
    <Color x:Key="BrandBlueSoft">#EDF4FF</Color>
    <Color x:Key="BrandPeachSoft">#FFF4EA</Color>
    <Color x:Key="BrandRoseSoft">#FFF1F5</Color>

    <SolidColorBrush x:Key="BrandOrangeBrush" Color="{StaticResource BrandOrange}" />
    <SolidColorBrush x:Key="BrandInkBrush" Color="{StaticResource BrandInk}" />
    <SolidColorBrush x:Key="BrandCanvasBrush" Color="{StaticResource BrandCanvas}" />
    <SolidColorBrush x:Key="BrandWhiteBrush" Color="{StaticResource BrandWhite}" />
</ResourceDictionary>
