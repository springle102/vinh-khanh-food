<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandBackground}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BrandStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="20,15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="52" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource BrandTextMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Stroke" Value="{StaticResource BrandStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BrandShadow}" Offset="0,6" Radius="18" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FloatingChipStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Stroke" Value="#F2ECE4" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BrandShadow}" Offset="0,5" Radius="14" Opacity="0.10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MapSearchContainerStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="MinimumHeightRequest" Value="56" />
        <Setter Property="Stroke" Value="#E9DFD3" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BrandShadow}" Offset="0,6" Radius="16" Opacity="0.10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MapChipStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="Stroke" Value="#ECE2D7" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BrandShadow}" Offset="0,4" Radius="12" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MapRoundActionStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="50" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="MinimumWidthRequest" Value="50" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="Stroke" Value="#ECE2D7" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BrandShadow}" Offset="0,5" Radius="12" Opacity="0.10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MapPrimaryFloatingActionStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="54" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#30F48A22" Offset="0,8" Radius="18" Opacity="0.22" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MapOverlayCaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <Style x:Key="ScreenTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
    </Style>

    <Style x:Key="MetaTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextSecondary}" />
    </Style>

    <Style x:Key="InputContainerStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Padding" Value="15,13" />
        <Setter Property="Stroke" Value="#E8DED1" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
        <Setter Property="BorderColor" Value="#DCD3C8" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,13" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>
</ResourceDictionary>
