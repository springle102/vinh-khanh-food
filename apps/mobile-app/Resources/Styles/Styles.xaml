<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandCanvas}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource BrandCanvas}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource BrandInk}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource BrandInk}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource BrandInk}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BrandStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandOrange}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource BrandInk}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource BrandMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource BrandInk}" />
        <Setter Property="TitleColor" Value="{StaticResource BrandMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource BrandOrange}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="#FFD5C1" />
        <Setter Property="ThumbColor" Value="White" />
    </Style>
</ResourceDictionary>
