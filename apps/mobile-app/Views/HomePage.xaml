<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
             x:Class="VinhKhanh.MobileApp.HomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BrandCanvas}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,22,20,120" Spacing="22">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding WelcomeTitle}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource BrandMuted}" />
                        <Label Text="Vĩnh Khánh"
                               FontSize="34"
                               FontAttributes="Bold,Italic"
                               TextColor="{StaticResource BrandOrange}" />
                    </VerticalStackLayout>

                    <ScrollView Grid.Column="1" Orientation="Horizontal">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Languages}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10"
                                            BackgroundColor="White"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource BrandOrange}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding BadgeCode}"
                                               FontSize="14"
                                               HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="White" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectLanguageCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </Grid>

                <Border HeightRequest="208" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 28">
                    <Border.Shadow>
                        <Shadow Brush="#170D2C" Offset="0,18" Opacity="0.12" Radius="28" />
                    </Border.Shadow>
                    <Grid>
                        <Image Source="{Binding HeroPoi.ThumbnailSource}" Aspect="AspectFill" />
                        <Border StrokeThickness="0">
                            <Border.Background>
                                <LinearGradientBrush EndPoint="0,1">
                                    <GradientStop Color="#050A1600" Offset="0.0" />
                                    <GradientStop Color="#09111F8F" Offset="0.55" />
                                    <GradientStop Color="#162239" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <VerticalStackLayout Padding="20" VerticalOptions="End" Spacing="6">
                            <Label Text="{Binding HeroTitle}" FontSize="30" FontAttributes="Bold" TextColor="White" />
                            <Label Text="{Binding HeroDescription}" FontSize="15" TextColor="#E7EDF8" />
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenHeroCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                    <Border Grid.Column="0" Padding="16,18" BackgroundColor="{StaticResource BrandPeachSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                            <Grid WidthRequest="28" HeightRequest="28">
                                <Path Data="M 14 26 C 20 18 24 13.5 24 9 C 24 3.5 19.5 0 14 0 C 8.5 0 4 3.5 4 9 C 4 13.5 8 18 14 26 Z"
                                      Stroke="#FF5A0A"
                                      Fill="Transparent"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round" />
                                <Path Data="M 14 12 A 3 3 0 1 1 13.99 12 Z"
                                      Stroke="#FF5A0A"
                                      Fill="Transparent"
                                      StrokeThickness="2" />
                            </Grid>
                            <Label Text="{Binding ListLabel}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenListCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="1" Padding="16,18" BackgroundColor="{StaticResource BrandRoseSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                            <Grid WidthRequest="28" HeightRequest="28">
                                <Path Data="M 2 2 H 10 V 10 H 2 Z M 18 2 H 26 V 10 H 18 Z M 2 18 H 10 V 26 H 2 Z"
                                      Stroke="#FF4C67"
                                      Fill="Transparent"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round" />
                                <Path Data="M 21.5 21.5 H 21.7 M 16 16 H 20 M 20 20 H 24 M 16 20 H 16.2 M 16 24 H 16.2 M 24 16 H 24.2"
                                      Stroke="#FF4C67"
                                      StrokeThickness="3"
                                      StrokeLineCap="Round" />
                            </Grid>
                            <Label Text="{Binding QrLabel}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenQrCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="2" Padding="16,18" BackgroundColor="{StaticResource BrandBlueSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                            <Grid WidthRequest="28" HeightRequest="28">
                                <Path Data="M 4 6 L 10 3 L 18 6 L 24 3 V 21 L 18 24 L 10 21 L 4 24 Z"
                                      Stroke="#3B82F6"
                                      Fill="Transparent"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round" />
                                <Path Data="M 10 3 V 21 M 18 6 V 24"
                                      Stroke="#3B82F6"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round" />
                            </Grid>
                            <Label Text="{Binding MapLabel}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMapCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <Border Padding="16,10" BackgroundColor="White" Stroke="{StaticResource BrandStroke}" StrokeShape="RoundRectangle 20">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Grid WidthRequest="22" HeightRequest="22" VerticalOptions="Center">
                            <Path Data="M 9.5 0.5 A 9 9 0 1 1 9.49 0.5 Z M 16 16 L 21 21"
                                  Stroke="{StaticResource BrandMuted}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round" />
                        </Grid>
                        <Entry Grid.Column="1"
                               Text="{Binding SearchText}"
                               Placeholder="{Binding SearchPlaceholder}"
                               ReturnCommand="{Binding OpenListCommand}" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Text="{Binding FeaturedSectionTitle}" FontSize="18" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding FeaturedActionText}" FontSize="15" TextColor="{StaticResource BrandOrange}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenListCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView ItemsSource="{Binding FeaturedPois}" HeightRequest="330" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="244" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 26">
                                <Border.Shadow>
                                    <Shadow Brush="#170D2C" Offset="0,16" Opacity="0.1" Radius="24" />
                                </Border.Shadow>
                                <Grid RowDefinitions="146,Auto">
                                    <Grid>
                                        <Image Source="{Binding ThumbnailSource}" Aspect="AspectFill" />
                                        <Border Margin="0" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="26,26,0,0" />
                                            </Border.StrokeShape>
                                        </Border>
                                        <Border HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                Margin="12"
                                                Padding="10,6"
                                                BackgroundColor="White"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="★" FontSize="12" TextColor="#FBBF24" />
                                                <Label Text="{Binding DisplayRating}" FontSize="12" FontAttributes="Bold" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                    <VerticalStackLayout Grid.Row="1" Padding="16,14,16,16" Spacing="8">
                                        <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding ShortDescription}" FontSize="13" TextColor="{StaticResource BrandInkSoft}" LineBreakMode="TailTruncation" MaxLines="2" />
                                        <Border Padding="10,6" HorizontalOptions="Start" BackgroundColor="{StaticResource BrandOrangePale}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                            <Label Text="{Binding CapsuleText}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource BrandOrange}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenFeaturedPoiCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <controls:AppBottomBar Grid.Row="1" CurrentRoute="HomePage" />

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
