<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.MobileApp.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BrandOrange}">
    <Grid Padding="28,32">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="28">
            <Grid WidthRequest="164" HeightRequest="164">
                <Border BackgroundColor="#FFFFFF33" StrokeThickness="0" StrokeShape="RoundRectangle 44" Margin="6,12,0,0" />
                <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 38">
                    <Border.Shadow>
                        <Shadow Brush="#3D1E00" Offset="0,18" Opacity="0.22" Radius="28" />
                    </Border.Shadow>
                    <Label Text="VK"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandOrange}" />
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="10">
                <Label Text="Vĩnh Khánh Food Guide"
                       HorizontalTextAlignment="Center"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="VĨNH KHÁNH FOOD STREET"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="4"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#FFE7D7" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="True" HorizontalOptions="Center" Color="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
