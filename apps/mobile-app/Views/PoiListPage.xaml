<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
             x:Class="VinhKhanh.MobileApp.PoiListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BrandCanvas}">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" Padding="22,24,22,0" RowDefinitions="Auto,Auto,Auto,*">
            <Label Text="Danh sách" FontSize="30" FontAttributes="Bold" />

            <Border Grid.Row="1" Margin="0,18,0,0" Padding="16,10" BackgroundColor="#F1F4F9" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Grid WidthRequest="22" HeightRequest="22" VerticalOptions="Center">
                        <Path Data="M 9.5 0.5 A 9 9 0 1 1 9.49 0.5 Z M 16 16 L 21 21"
                              Stroke="{StaticResource BrandMuted}"
                              StrokeThickness="2"
                              StrokeLineCap="Round" />
                    </Grid>
                    <Entry Grid.Column="1" Text="{Binding SearchText}" Placeholder="Tìm kiếm..." />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,16,0,12" ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Label Text="◀" FontSize="13" TextColor="{StaticResource BrandInkSoft}" VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScrollCategoriesLeft" />
                    </Label.GestureRecognizers>
                </Label>
                <ScrollView x:Name="CategoryScrollView" Grid.Column="1" Orientation="Horizontal">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Categories}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,8"
                                        BackgroundColor="White"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 18">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource BrandOrange}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectCategoryCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
                <Label Grid.Column="2" Text="▶" FontSize="13" TextColor="{StaticResource BrandInkSoft}" VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScrollCategoriesRight" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <CollectionView Grid.Row="3" ItemsSource="{Binding FilteredPois}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,16" Padding="10" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 26">
                            <Border.Shadow>
                                <Shadow Brush="#140F24" Offset="0,14" Opacity="0.08" Radius="20" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="106,*,Auto" ColumnSpacing="14">
                                <Grid>
                                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 20">
                                        <Image Source="{Binding ThumbnailSource}" Aspect="AspectFill" HeightRequest="96" WidthRequest="106" />
                                    </Border>
                                    <Border HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                            Margin="-4,-4,0,0"
                                            Padding="8,4"
                                            BackgroundColor="White"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="★" FontSize="11" TextColor="#FBBF24" />
                                            <Label Text="{Binding DisplayRating}" FontSize="11" FontAttributes="Bold" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding AreaText}" FontSize="13" TextColor="{StaticResource BrandInkSoft}" />
                                    <Border Padding="8,4" HorizontalOptions="Start" BackgroundColor="{StaticResource BrandCanvas}" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                        <Label Text="{Binding CapsuleText}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource BrandInkSoft}" />
                                    </Border>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="28" TextColor="{StaticResource BrandMuted}" VerticalTextAlignment="Center" />
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenPoiCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

        <controls:AppBottomBar Grid.Row="1" CurrentRoute="PoiListPage" />
    </Grid>
</ContentPage>
