<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.MobileApp.LanguageSelectionPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BrandCanvas}">
    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,36,24,28" BackgroundColor="{StaticResource BrandOrange}">
            <VerticalStackLayout Spacing="14">
                <Label Text="Chọn ngôn ngữ" FontSize="30" FontAttributes="Bold" TextColor="White" />
                <Label Text="Ứng dụng sẽ giữ nguyên backend và dữ liệu cũ, chỉ thay giao diện theo thiết kế mới của bạn."
                       FontSize="15"
                       TextColor="#FFE6D6" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,24,24,40" Spacing="18">
                <Border Padding="10" BackgroundColor="White" Stroke="{StaticResource BrandStroke}" StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Languages}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="14,18" ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            BackgroundColor="{StaticResource BrandOrangePale}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Label Text="{Binding BadgeCode}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" Spacing="2">
                                        <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="Nhấn để tiếp tục" FontSize="13" TextColor="{StaticResource BrandInkSoft}" />
                                    </VerticalStackLayout>
                                    <BoxView Grid.Column="2"
                                             WidthRequest="10"
                                             HeightRequest="10"
                                             Color="{StaticResource BrandOrange}"
                                             CornerRadius="5"
                                             IsVisible="{Binding IsSelected}"
                                             VerticalOptions="Center" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectLanguageCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
