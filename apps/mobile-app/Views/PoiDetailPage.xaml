<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.MobileApp.PoiDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BrandCanvas}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="0,0,0,32" Spacing="0">
                <Grid HeightRequest="300">
                    <Image Source="{Binding Detail.ThumbnailSource}" Aspect="AspectFill" />
                    <Border StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#080D1600" Offset="0.0" />
                                <GradientStop Color="#09111F55" Offset="0.55" />
                                <GradientStop Color="#162239" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border Margin="18,26,0,0"
                            WidthRequest="46"
                            HeightRequest="46"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            BackgroundColor="#FFFFFFCC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18">
                        <Label Text="←" HorizontalOptions="Center" VerticalOptions="Center" FontSize="22" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <VerticalStackLayout Padding="22" VerticalOptions="End" Spacing="6">
                        <Label Text="{Binding Detail.Title}" FontSize="30" FontAttributes="Bold" TextColor="White" />
                        <Label Text="{Binding Detail.ShortDescription}" FontSize="15" TextColor="#E8EEF8" />
                    </VerticalStackLayout>
                </Grid>

                <Border Margin="20,-28,20,0" Padding="20" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 30">
                    <Border.Shadow>
                        <Shadow Brush="#140F24" Offset="0,16" Opacity="0.12" Radius="24" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="18">
                        <HorizontalStackLayout Spacing="10">
                            <Border Padding="10,6" BackgroundColor="{StaticResource BrandOrangePale}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                <Label Text="{Binding Detail.CategoryDisplay}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource BrandOrange}" />
                            </Border>
                            <Border Padding="10,6" BackgroundColor="{StaticResource BrandCanvas}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                <Label Text="{Binding Detail.OpeningHours}" FontSize="12" TextColor="{StaticResource BrandInkSoft}" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="{Binding Detail.FullDescription}" FontSize="14" TextColor="{StaticResource BrandInkSoft}" />
                        <Label Text="{Binding Detail.Address}" FontSize="14" />

                        <HorizontalStackLayout Spacing="10">
                            <Button Text="{Binding PlayText}" Command="{Binding PlayCommand}" />
                            <Button Text="{Binding PauseText}"
                                    Command="{Binding PauseCommand}"
                                    BackgroundColor="{StaticResource BrandOrangePale}"
                                    TextColor="{StaticResource BrandOrange}" />
                            <Button Text="Chỉ đường"
                                    Command="{Binding OpenDirectionsCommand}"
                                    BackgroundColor="{StaticResource BrandInk}"
                                    TextColor="White" />
                        </HorizontalStackLayout>

                        <Label Text="Món nổi bật" FontSize="20" FontAttributes="Bold" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Detail.FoodItems}" Spacing="12">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14" BackgroundColor="{StaticResource BrandCanvas}" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                            <Label Text="{Binding Description}" FontSize="13" TextColor="{StaticResource BrandInkSoft}" />
                                            <Label Text="{Binding PriceRange}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource BrandOrange}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
