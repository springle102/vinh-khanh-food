<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="VinhKhanh.MobileApp.Controls.POIDetailBottomSheet"
    x:Name="SheetRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:VinhKhanh.MobileApp.Models"
    xmlns:viewModels="clr-namespace:VinhKhanh.MobileApp.ViewModels"
    x:DataType="viewModels:HomeMapViewModel"
    IsVisible="False"
    SizeChanged="OnRootSizeChanged">

    <Grid>
        <BoxView
            x:Name="Backdrop"
            BackgroundColor="#66111922"
            Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Grid Padding="12,16,12,12" VerticalOptions="Fill">
            <Border
                x:Name="SheetBorder"
                BackgroundColor="White"
                HeightRequest="420"
                MaximumHeightRequest="720"
                Opacity="0"
                Padding="0"
                Stroke="#EEDFD0"
                StrokeShape="RoundRectangle 28"
                TranslationY="56"
                VerticalOptions="End">
                <Border.Shadow>
                    <Shadow Brush="#22000000" Offset="0,-4" Radius="24" Opacity="0.22" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <Grid
                        x:Name="SheetHeader"
                        Padding="18,14,18,10"
                        ColumnDefinitions="*,Auto,*">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnHandlePanUpdated" />
                        </Grid.GestureRecognizers>

                        <Border
                            Grid.Column="1"
                            BackgroundColor="#E8DFD4"
                            HeightRequest="5"
                            HorizontalOptions="Center"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3"
                            VerticalOptions="Center"
                            WidthRequest="54" />

                        <Border
                            Grid.Column="2"
                            BackgroundColor="#F8F3EC"
                            HeightRequest="34"
                            HorizontalOptions="End"
                            Stroke="#EADFD3"
                            StrokeShape="RoundRectangle 17"
                            WidthRequest="34">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseTapped" />
                            </Border.GestureRecognizers>
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="X"
                                TextColor="#7A5130"
                                VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="HeroContainer"
                        Grid.Row="1"
                        HeightRequest="196">
                        <CarouselView
                            x:Name="ImageCarousel"
                            IndicatorView="{x:Reference SheetIndicator}"
                            ItemsSource="{Binding DetailImages}">
                            <CarouselView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Grid>
                                        <Image Aspect="AspectFill" Source="{Binding .}" />
                                        <Grid>
                                            <Grid.Background>
                                                <LinearGradientBrush EndPoint="0,1">
                                                    <GradientStop Color="#05000000" Offset="0.0" />
                                                    <GradientStop Color="#26000000" Offset="0.8" />
                                                    <GradientStop Color="#3F000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>

                        <Border
                            BackgroundColor="#FDF2E2"
                            HorizontalOptions="Start"
                            IsVisible="{Binding IsFeaturedPoi}"
                            Margin="14,14,0,0"
                            Padding="10,6"
                            Stroke="#F0C48F"
                            StrokeShape="RoundRectangle 14"
                            VerticalOptions="Start">
                            <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding FeaturedBadgeText}" TextColor="#A85D10" />
                        </Border>

                        <Border
                            BackgroundColor="#B2111720"
                            HorizontalOptions="End"
                            IsVisible="{Binding IsPoiDetailLoading}"
                            Margin="0,0,14,14"
                            Padding="10,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            VerticalOptions="End">
                            <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding DetailLoadingText}" TextColor="White" />
                        </Border>

                        <IndicatorView
                            x:Name="SheetIndicator"
                            HorizontalOptions="Center"
                            IndicatorColor="#D6C3AE"
                            Margin="0,0,0,14"
                            SelectedIndicatorColor="White"
                            VerticalOptions="End" />
                    </Grid>

                    <ScrollView x:Name="SheetScrollView" Grid.Row="2">
                        <VerticalStackLayout x:Name="SheetContent" Padding="18,18,18,0" Spacing="16">
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="26"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding SelectedPoiTitle}" />

                                <HorizontalStackLayout Spacing="10">
                                    <Border
                                        BackgroundColor="#FFF2E3"
                                        IsVisible="{Binding HasRatingSummary}"
                                        Padding="10,6"
                                        Stroke="#F1D2AE"
                                        StrokeShape="RoundRectangle 14">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label FontFamily="OpenSansSemibold" FontSize="12" Text="*" TextColor="#D97706" />
                                            <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding SelectedPoiRatingText}" TextColor="#8A4B0D" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <Border
                                        BackgroundColor="#F7F4F0"
                                        Padding="10,6"
                                        Stroke="#E8DFD4"
                                        StrokeShape="RoundRectangle 14">
                                        <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding SelectedPoiCategory}" TextColor="{StaticResource BrandTextPrimary}" />
                                    </Border>

                                    <Border
                                        BackgroundColor="#F7F4F0"
                                        IsVisible="{Binding HasReviewSummary}"
                                        Padding="10,6"
                                        Stroke="#E8DFD4"
                                        StrokeShape="RoundRectangle 14">
                                        <Label FontSize="12" Text="{Binding SelectedPoiReviewText}" TextColor="{StaticResource BrandTextSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Border
                                BackgroundColor="#FBF8F3"
                                Padding="12,10"
                                Stroke="#EEE2D6"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="6">
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding AddressLabelText}" TextColor="{StaticResource BrandTextMuted}" />
                                    <Label LineBreakMode="WordWrap" Text="{Binding SelectedPoiAddress}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                BackgroundColor="#F8F4EE"
                                IsVisible="{Binding IsSelectedPoiSimulationCardVisible}"
                                Padding="12,12"
                                Stroke="#E7DCCF"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border
                                            WidthRequest="34"
                                            HeightRequest="34"
                                            BackgroundColor="#E8F0FF"
                                            Stroke="#C7D8FF"
                                            StrokeShape="RoundRectangle 17"
                                            VerticalOptions="Start">
                                            <Label
                                                FontFamily="OpenSansSemibold"
                                                FontSize="15"
                                                HorizontalTextAlignment="Center"
                                                Text="•"
                                                TextColor="#3159B8"
                                                VerticalTextAlignment="Center" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label
                                                FontFamily="OpenSansSemibold"
                                                FontSize="14"
                                                Text="{Binding PoiSimulationTitleText}"
                                                TextColor="{StaticResource BrandTextPrimary}" />
                                            <Label
                                                FontSize="12"
                                                LineBreakMode="WordWrap"
                                                Text="{Binding SelectedPoiSimulationDescriptionText}"
                                                TextColor="{StaticResource BrandTextSecondary}" />
                                            <Label
                                                FontFamily="OpenSansSemibold"
                                                FontSize="11"
                                                Text="{Binding SelectedPoiSimulationStatusText}"
                                                TextColor="#8B5E35" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button
                                            BackgroundColor="#FFF2E3"
                                            BorderColor="#F1D2AE"
                                            BorderWidth="1"
                                            Command="{Binding OpenDirectionsCommand}"
                                            CornerRadius="14"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            IsEnabled="{Binding CanBuildRoute}"
                                            Padding="12,10"
                                            Text="{Binding DirectionsActionText}"
                                            TextColor="#A85D10" />

                                        <Button
                                            Grid.Column="1"
                                            BackgroundColor="{StaticResource BrandPrimary}"
                                            Command="{Binding StartSelectedPoiSimulationCommand}"
                                            CornerRadius="14"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            IsEnabled="{Binding CanStartSelectedPoiSimulation}"
                                            Padding="12,10"
                                            Text="{Binding StartSimulationText}"
                                            TextColor="White" />
                                    </Grid>

                                    <Grid
                                        ColumnDefinitions="*,*"
                                        ColumnSpacing="10"
                                        IsVisible="{Binding HasSelectedPoiSimulationRoute}">
                                        <Button
                                            BackgroundColor="#FAF6F0"
                                            BorderColor="#E6D9CA"
                                            BorderWidth="1"
                                            Command="{Binding PauseSelectedPoiSimulationCommand}"
                                            CornerRadius="14"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            IsEnabled="{Binding CanPauseSelectedPoiSimulation}"
                                            Padding="12,10"
                                            Text="{Binding PauseSimulationText}"
                                            TextColor="{StaticResource BrandTextPrimary}" />

                                        <Button
                                            Grid.Column="1"
                                            BackgroundColor="#FAF6F0"
                                            BorderColor="#E6D9CA"
                                            BorderWidth="1"
                                            Command="{Binding StopSelectedPoiSimulationCommand}"
                                            CornerRadius="14"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            IsEnabled="{Binding CanStopSelectedPoiSimulation}"
                                            Padding="12,10"
                                            Text="{Binding StopSimulationText}"
                                            TextColor="{StaticResource BrandTextPrimary}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                BackgroundColor="#FBF8F3"
                                IsVisible="{Binding HasSelectedPoiPriceRange}"
                                Padding="12,10"
                                Stroke="#EEE2D6"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="6">
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding PriceRangeLabelText}" TextColor="{StaticResource BrandTextMuted}" />
                                    <Label LineBreakMode="WordWrap" Text="{Binding SelectedPoiPriceRange}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                BackgroundColor="#FBF8F3"
                                IsVisible="{Binding HasSelectedPoiOpeningHours}"
                                Padding="12,10"
                                Stroke="#EEE2D6"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="6">
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding OpeningHoursLabelText}" TextColor="{StaticResource BrandTextMuted}" />
                                    <Label LineBreakMode="WordWrap" Text="{Binding SelectedPoiOpeningHours}" />
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontSize="15"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2"
                                    Text="{Binding SelectedPoiSummary}"
                                    TextColor="{StaticResource BrandTextSecondary}" />
                                <Label
                                    FontSize="14"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding SelectedPoiDescription}"
                                    TextColor="{StaticResource BrandTextPrimary}" />
                            </VerticalStackLayout>

                            <Border
                                BackgroundColor="#F5F2ED"
                                IsVisible="{Binding IsAutoNarrationDevToolsVisible}"
                                Padding="12,10"
                                Stroke="#E5DCCF"
                                StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            FontFamily="OpenSansSemibold"
                                            FontSize="13"
                                            Text="{Binding AutoNarrationDevTitleText}"
                                            TextColor="{StaticResource BrandTextPrimary}" />
                                        <Label
                                            FontSize="12"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding AutoNarrationDevDescriptionText}"
                                            TextColor="{StaticResource BrandTextSecondary}" />
                                    </VerticalStackLayout>

                                    <Button
                                        Grid.Column="1"
                                        BackgroundColor="#FFF2E3"
                                        BorderColor="#F1D2AE"
                                        BorderWidth="1"
                                        Command="{Binding SimulateNearSelectedPoiCommand}"
                                        CornerRadius="14"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="11"
                                        Padding="12,10"
                                        Text="{Binding SimulateNearSelectedPoiText}"
                                        TextColor="#A85D10"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <VerticalStackLayout IsVisible="{Binding HasSelectedPoiTags}" Spacing="10">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="16"
                                    Text="{Binding TagsLabelText}"
                                    TextColor="{StaticResource BrandTextPrimary}" />
                                <FlexLayout
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding SelectedPoiTags}"
                                    Direction="Row"
                                    Wrap="Wrap">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="{x:Null}">
                                            <Border
                                                BackgroundColor="#F8F3EC"
                                                Margin="0,0,8,8"
                                                Padding="10,6"
                                                Stroke="#EADFD3"
                                                StrokeShape="RoundRectangle 14">
                                                <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding .}" TextColor="#7A5130" />
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="10">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="16"
                                    Text="{Binding FoodItemsLabelText}"
                                    TextColor="{StaticResource BrandTextPrimary}" />

                                <VerticalStackLayout
                                    BindableLayout.ItemsSource="{Binding SelectedPoiFoodItems}"
                                    IsVisible="{Binding HasSelectedPoiFoodItems}"
                                    Spacing="12">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:PoiFoodItemDetail">
                                            <Border
                                                BackgroundColor="#FBF8F3"
                                                Padding="12"
                                                Stroke="#EEE2D6"
                                                StrokeShape="RoundRectangle 18">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border
                                                        BackgroundColor="#F2E7D9"
                                                        HeightRequest="78"
                                                        IsVisible="{Binding HasImage}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16"
                                                        WidthRequest="78">
                                                        <Image Aspect="AspectFill" Source="{Binding ImageUrl}" />
                                                    </Border>

                                                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <Label
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="15"
                                                                LineBreakMode="WordWrap"
                                                                Text="{Binding Name}"
                                                                TextColor="{StaticResource BrandTextPrimary}" />
                                                            <Border
                                                                Grid.Column="1"
                                                                BackgroundColor="#FFF2E3"
                                                                IsVisible="{Binding HasSpicyLevel}"
                                                                Padding="8,4"
                                                                Stroke="#F1D2AE"
                                                                StrokeShape="RoundRectangle 12">
                                                                <Label FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding SpicyLevelLabel}" TextColor="#A85D10" />
                                                            </Border>
                                                        </Grid>

                                                        <Label
                                                            FontSize="13"
                                                            IsVisible="{Binding HasDescription}"
                                                            LineBreakMode="WordWrap"
                                                            Text="{Binding Description}"
                                                            TextColor="{StaticResource BrandTextSecondary}" />

                                                        <Label
                                                            FontFamily="OpenSansSemibold"
                                                            FontSize="13"
                                                            IsVisible="{Binding HasPriceRange}"
                                                            Text="{Binding PriceRange}"
                                                            TextColor="#B4571D" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <Label
                                    FontSize="13"
                                    IsVisible="{Binding ShowSelectedPoiFoodItemsEmptyState}"
                                    Text="{Binding NoFoodItemsText}"
                                    TextColor="{StaticResource BrandTextSecondary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="10">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="16"
                                    Text="{Binding PromotionsLabelText}"
                                    TextColor="{StaticResource BrandTextPrimary}" />

                                <VerticalStackLayout
                                    BindableLayout.ItemsSource="{Binding SelectedPoiPromotions}"
                                    IsVisible="{Binding HasSelectedPoiPromotions}"
                                    Spacing="12">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:PoiPromotionDetail">
                                            <Border
                                                BackgroundColor="#FBF8F3"
                                                Padding="12"
                                                Stroke="#EEE2D6"
                                                StrokeShape="RoundRectangle 18">
                                                <VerticalStackLayout Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <Label
                                                            FontFamily="OpenSansSemibold"
                                                            FontSize="15"
                                                            LineBreakMode="WordWrap"
                                                            Text="{Binding Title}"
                                                            TextColor="{StaticResource BrandTextPrimary}" />
                                                        <Border
                                                            Grid.Column="1"
                                                            BackgroundColor="{Binding StatusBackgroundColor}"
                                                            Padding="8,4"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 12">
                                                            <Label FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding StatusLabel}" TextColor="{Binding StatusTextColor}" />
                                                        </Border>
                                                    </Grid>

                                                    <Label
                                                        FontSize="13"
                                                        IsVisible="{Binding HasDescription}"
                                                        LineBreakMode="WordWrap"
                                                        Text="{Binding Description}"
                                                        TextColor="{StaticResource BrandTextSecondary}" />

                                                    <Label
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="12"
                                                        IsVisible="{Binding HasPeriod}"
                                                        Text="{Binding PeriodText}"
                                                        TextColor="#7A5130" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <Label
                                    FontSize="13"
                                    IsVisible="{Binding ShowSelectedPoiPromotionsEmptyState}"
                                    Text="{Binding NoPromotionsText}"
                                    TextColor="{StaticResource BrandTextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                BackgroundColor="#F8F3EC"
                                IsVisible="{Binding IsPoiDetailLoading}"
                                Padding="14"
                                Stroke="#EADFD3"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="10">
                                    <BoxView Color="#E6DDD1" CornerRadius="8" HeightRequest="14" WidthRequest="170" />
                                    <BoxView Color="#EEE5DA" CornerRadius="8" HeightRequest="12" />
                                    <BoxView Color="#EEE5DA" CornerRadius="8" HeightRequest="12" WidthRequest="240" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Grid Grid.Row="3" Padding="18,16,18,18" ColumnDefinitions="*">
                        <Border
                            BackgroundColor="{StaticResource BrandPrimary}"
                            Margin="0"
                            Padding="10,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label FontSize="17" HorizontalTextAlignment="Center" Text=">" TextColor="White" />
                                <Label FontFamily="OpenSansSemibold" FontSize="11" HorizontalTextAlignment="Center" Text="{Binding ListenActionText}" TextColor="White" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PlayNarrationCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
