<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="VinhKhanh.MobileApp.Controls.AppBottomBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid HeightRequest="104">
        <Border
            Margin="0,22,0,0"
            Padding="18,12,18,14"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24,24,0,0">
            <Border.Shadow>
                <Shadow Brush="#160B2F" Offset="0,-6" Opacity="0.08" Radius="20" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,92,*,*" RowDefinitions="Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Grid WidthRequest="24" HeightRequest="24">
                        <Path
                            x:Name="HomePath"
                            Aspect="Uniform"
                            Data="M 3 10.5 L 12 3 L 21 10.5 V 20 A 1 1 0 0 1 20 21 H 15 V 14 H 9 V 21 H 4 A 1 1 0 0 1 3 20 Z"
                            StrokeThickness="1.8"
                            StrokeLineJoin="Round"
                            StrokeLineCap="Round" />
                    </Grid>
                    <Label x:Name="HomeLabel" FontSize="10" HorizontalTextAlignment="Center" Text="TRANG CHỦ" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Grid WidthRequest="24" HeightRequest="24">
                        <Path
                            x:Name="MapPath1"
                            Aspect="Uniform"
                            Data="M 4 6 L 9 4 L 15 6 L 20 4 V 18 L 15 20 L 9 18 L 4 20 Z"
                            StrokeThickness="1.8"
                            StrokeLineJoin="Round"
                            StrokeLineCap="Round" />
                        <Path
                            x:Name="MapPath2"
                            Aspect="Uniform"
                            Data="M 9 4 V 18 M 15 6 V 20"
                            StrokeThickness="1.8"
                            StrokeLineJoin="Round"
                            StrokeLineCap="Round" />
                    </Grid>
                    <Label x:Name="MapLabel" FontSize="10" HorizontalTextAlignment="Center" Text="BẢN ĐỒ" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <Grid WidthRequest="24" HeightRequest="24">
                        <Path
                            x:Name="ListPath1"
                            Aspect="Uniform"
                            Data="M 5 6 H 19 M 5 12 H 19 M 5 18 H 19"
                            StrokeThickness="1.8"
                            StrokeLineCap="Round" />
                        <Path
                            x:Name="ListPath2"
                            Aspect="Uniform"
                            Data="M 3.5 6 H 3.6 M 3.5 12 H 3.6 M 3.5 18 H 3.6"
                            StrokeThickness="3"
                            StrokeLineCap="Round" />
                    </Grid>
                    <Label x:Name="ListLabel" FontSize="10" HorizontalTextAlignment="Center" Text="DANH SÁCH" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnListTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <Grid WidthRequest="24" HeightRequest="24">
                        <Path
                            x:Name="SettingsPath1"
                            Aspect="Uniform"
                            Data="M 12 8.2 A 3.8 3.8 0 1 1 11.99 8.2 Z"
                            StrokeThickness="1.8"
                            StrokeLineJoin="Round"
                            StrokeLineCap="Round" />
                        <Path
                            x:Name="SettingsPath2"
                            Aspect="Uniform"
                            Data="M 12 2.8 V 5 M 12 19 V 21.2 M 3.7 7.2 L 5.7 8.3 M 18.3 15.7 L 20.3 16.8 M 3.7 16.8 L 5.7 15.7 M 18.3 8.3 L 20.3 7.2 M 2.8 12 H 5 M 19 12 H 21.2"
                            StrokeThickness="1.8"
                            StrokeLineCap="Round" />
                    </Grid>
                    <Label x:Name="SettingsLabel" FontSize="10" HorizontalTextAlignment="Center" Text="CÀI ĐẶT" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Border
            x:Name="QrButton"
            WidthRequest="72"
            HeightRequest="72"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            BackgroundColor="#FF5A0A"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 36">
            <Border.Shadow>
                <Shadow Brush="#FF5A0A" Offset="0,10" Opacity="0.28" Radius="20" />
            </Border.Shadow>

            <Grid WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" VerticalOptions="Center">
                <Path
                    x:Name="QrPath1"
                    Aspect="Uniform"
                    Data="M 2 2 H 10 V 10 H 2 Z M 14 2 H 22 V 10 H 14 Z M 2 14 H 10 V 22 H 2 Z"
                    Stroke="White"
                    Fill="Transparent"
                    StrokeThickness="2"
                    StrokeLineJoin="Round" />
                <Path
                    x:Name="QrPath2"
                    Aspect="Uniform"
                    Data="M 5.8 5.8 H 6.2 M 17.8 5.8 H 18.2 M 5.8 17.8 H 6.2 M 14 14 H 18 M 18 18 H 22 M 18 22 H 22 M 14 18 H 14.4 M 14 22 H 14.4 M 22 14 H 22.4"
                    Stroke="White"
                    StrokeThickness="3"
                    StrokeLineCap="Round" />
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnQrTapped" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentView>
