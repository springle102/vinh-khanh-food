<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.MobileApp.Pages.QrScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    BackgroundColor="#111A2D"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <Grid>
            <zxing:CameraBarcodeReaderView
                x:Name="BarcodeReader"
                BarcodesDetected="OnBarcodesDetected" />

            <Grid Padding="20,22,20,128" RowDefinitions="Auto,*,Auto">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border WidthRequest="46" HeightRequest="46" BackgroundColor="#2A3447" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                        <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="19" Text="&#x2715;" TextColor="White" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="2" WidthRequest="46" HeightRequest="46" BackgroundColor="#2A3447" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                        <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" Text="&#x26A1;" TextColor="White" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTorchTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="272" HeightRequest="272">
                    <Border BackgroundColor="#33000000" Stroke="#66FFFFFF" StrokeThickness="1" StrokeShape="RoundRectangle 32" />

                    <Border WidthRequest="66" HeightRequest="66" HorizontalOptions="Start" VerticalOptions="Start" BackgroundColor="#00000000" Stroke="{StaticResource BrandPrimary}" StrokeThickness="4" StrokeShape="RoundRectangle 18" />
                    <Border WidthRequest="66" HeightRequest="66" HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#00000000" Stroke="{StaticResource BrandPrimary}" StrokeThickness="4" StrokeShape="RoundRectangle 18" />
                    <Border WidthRequest="66" HeightRequest="66" HorizontalOptions="Start" VerticalOptions="End" BackgroundColor="#00000000" Stroke="{StaticResource BrandPrimary}" StrokeThickness="4" StrokeShape="RoundRectangle 18" />
                    <Border WidthRequest="66" HeightRequest="66" HorizontalOptions="End" VerticalOptions="End" BackgroundColor="#00000000" Stroke="{StaticResource BrandPrimary}" StrokeThickness="4" StrokeShape="RoundRectangle 18" />

                    <BoxView WidthRequest="188" HeightRequest="3" HorizontalOptions="Center" VerticalOptions="Center" Color="{StaticResource BrandPrimary}" Opacity="0.92" />
                </Grid>

                <VerticalStackLayout Grid.Row="2" Spacing="14">
                    <Label HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" FontSize="26" Text="Quet QR" TextColor="White" />
                    <Label
                        HorizontalTextAlignment="Center"
                        FontSize="14"
                        Text="Dua ma QR vao trong khung de chon ngon ngu va tiep tuc trai nghiem."
                        TextColor="#D6DEEC" />

                    <Border Padding="16,14" BackgroundColor="#2A3447" Stroke="#44506A" StrokeShape="RoundRectangle 18">
                        <HorizontalStackLayout Spacing="12">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#1AF48A22" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                                <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="17" Text="QR" TextColor="{StaticResource BrandPrimary}" />
                            </Border>
                            <VerticalStackLayout Spacing="4">
                                <Label FontFamily="OpenSansSemibold" Text="Nhap ma thu cong" TextColor="White" />
                                <Label FontSize="12" Text="Dung de test nhanh bang poi id, vi du: poi-bbq-night" TextColor="#C9D2E3" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnManualTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <controls:AppBottomBar Grid.Row="1" />
    </Grid>
</ContentPage>
