<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.MobileApp.Pages.StartupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F59E0B">

    <Grid Padding="28,32">
        <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="26">
            <Border
                WidthRequest="148"
                HeightRequest="148"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 34">
                <Label
                    Text="VK"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="42"
                    TextColor="#F59E0B" />
            </Border>

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Vinh Khanh Food Guide"
                    FontAttributes="Bold"
                    FontSize="28"
                    HorizontalTextAlignment="Center"
                    TextColor="White" />
                <ActivityIndicator
                    IsRunning="True"
                    Color="White"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
