<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.MobileApp.Pages.QRSuccessLanguagePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
    xmlns:models="clr-namespace:VinhKhanh.MobileApp.Models"
    xmlns:viewModels="clr-namespace:VinhKhanh.MobileApp.ViewModels"
    x:DataType="viewModels:QRSuccessLanguageViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <Grid>
            <Image Aspect="AspectFill" Source="{Binding BackgroundImageUrl}" />
            <Border BackgroundColor="#66152138" StrokeThickness="0" />

            <Border StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#B20D2C58" Offset="0.0" />
                        <GradientStop Color="#CC152138" Offset="0.45" />
                        <GradientStop Color="#F2152138" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <ScrollView>
                <VerticalStackLayout Padding="24,28,24,130" Spacing="20">
                    <Label
                        HorizontalTextAlignment="End"
                        Text="Vinh Khanh&#10;Food Street"
                        TextColor="{StaticResource BrandGold}"
                        FontFamily="OpenSansSemibold"
                        FontSize="18" />

                    <Border Margin="0,28,0,0" Padding="22" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 30">
                        <Border.Shadow>
                            <Shadow Brush="#33000000" Offset="0,16" Radius="28" Opacity="0.22" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="18">
                            <Label HorizontalTextAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="{Binding ScanSuccessText}" />

                            <Grid HeightRequest="120" ColumnDefinitions="*,*,*,*,*" Margin="6,0">
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="6" VerticalOptions="End">
                                    <Border BackgroundColor="#FFE7C6" StrokeThickness="0" WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 17" />
                                    <Border BackgroundColor="#E67A4A" StrokeThickness="0" WidthRequest="26" HeightRequest="40" StrokeShape="RoundRectangle 13" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="6" VerticalOptions="Center">
                                    <Border BackgroundColor="#FFD9B0" StrokeThickness="0" WidthRequest="38" HeightRequest="38" StrokeShape="RoundRectangle 19" />
                                    <Border BackgroundColor="#3C86F0" StrokeThickness="0" WidthRequest="28" HeightRequest="44" StrokeShape="RoundRectangle 14" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="6" VerticalOptions="End">
                                    <Border BackgroundColor="#FFE7C6" StrokeThickness="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" />
                                    <Border BackgroundColor="#F3A43B" StrokeThickness="0" WidthRequest="30" HeightRequest="48" StrokeShape="RoundRectangle 15" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="6" VerticalOptions="Center">
                                    <Border BackgroundColor="#FFD9B0" StrokeThickness="0" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" />
                                    <Border BackgroundColor="#F36D5D" StrokeThickness="0" WidthRequest="28" HeightRequest="42" StrokeShape="RoundRectangle 14" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="6" VerticalOptions="End">
                                    <Border BackgroundColor="#FFE7C6" StrokeThickness="0" WidthRequest="38" HeightRequest="38" StrokeShape="RoundRectangle 19" />
                                    <Border BackgroundColor="#F28A4B" StrokeThickness="0" WidthRequest="28" HeightRequest="44" StrokeShape="RoundRectangle 14" />
                                </VerticalStackLayout>

                                <Border TranslationX="18" TranslationY="10" WidthRequest="28" HeightRequest="28" HorizontalOptions="Start" VerticalOptions="Start" BackgroundColor="#F6F5FF" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                                    <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Text="🌎" FontSize="15" />
                                </Border>
                                <Border TranslationY="0" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Start" BackgroundColor="#FFF6DF" StrokeThickness="0" StrokeShape="RoundRectangle 15">
                                    <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Text="💬" FontSize="15" />
                                </Border>
                                <Border TranslationX="-14" TranslationY="12" WidthRequest="28" HeightRequest="28" HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#EAF4FF" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                                    <Label HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Text="🈯" FontSize="15" />
                                </Border>
                            </Grid>

                            <Label HorizontalTextAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="{Binding ChooseLanguageText}" />

                            <CollectionView ItemsSource="{Binding Languages}" SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:LanguageOption">
                                        <Border Padding="12,14" BackgroundColor="White" Stroke="{StaticResource BrandStrokeStrong}" StrokeShape="RoundRectangle 18">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimaryPale}" />
                                                    <Setter Property="Stroke" Value="{StaticResource BrandPrimary}" />
                                                    <Setter Property="StrokeThickness" Value="1.6" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                                <Label FontSize="34" HorizontalTextAlignment="Center" Text="{Binding Flag}" />
                                                <Label FontFamily="OpenSansSemibold" HorizontalTextAlignment="Center" Text="{Binding DisplayName}" />
                                            </VerticalStackLayout>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectLanguageCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button Margin="0,10,0,0" Command="{Binding ContinueCommand}" Text="{Binding ContinueText}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <controls:AppBottomBar Grid.Row="1" CurrentRoute="QRSuccessLanguagePage" />
    </Grid>
</ContentPage>
