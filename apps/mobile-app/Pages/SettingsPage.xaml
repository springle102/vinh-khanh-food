<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.MobileApp.Pages.SettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
    xmlns:models="clr-namespace:VinhKhanh.MobileApp.Models"
    xmlns:viewModels="clr-namespace:VinhKhanh.MobileApp.ViewModels"
    x:DataType="viewModels:SettingsViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource BrandBackground}">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="22,34,22,104" Spacing="22">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="29"
                    HorizontalTextAlignment="Start"
                    Text="{Binding HeaderTitleText}"
                    TextColor="{StaticResource BrandTextPrimary}" />

                <Label
                    BackgroundColor="#FFF4E7"
                    FontSize="13"
                    IsVisible="{Binding HasLoadError}"
                    LineBreakMode="WordWrap"
                    Padding="12,10"
                    Text="{Binding LoadErrorText}"
                    TextColor="#A85D10" />

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label
                            FontSize="17"
                            Text="◎"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                        <Label
                            Grid.Column="1"
                            CharacterSpacing="1.3"
                            FontFamily="OpenSansSemibold"
                            FontSize="13"
                            Text="{Binding LanguageSectionText}"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                    </Grid>

                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Languages}"
                        Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:LanguageOption">
                                <Border
                                    Padding="16,0"
                                    BackgroundColor="#FFFDFC"
                                    MinimumHeightRequest="58"
                                    Stroke="#F0E7DD"
                                    StrokeShape="RoundRectangle 13">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="White" />
                                            <Setter Property="Stroke" Value="{StaticResource BrandPrimary}" />
                                            <Setter Property="StrokeThickness" Value="1.6" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="8">
                                        <Label
                                            FontFamily="OpenSansSemibold"
                                            FontSize="15"
                                            Text="{Binding BadgeCode}"
                                            TextColor="{StaticResource BrandTextPrimary}"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            Grid.Column="1"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="14"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding DisplayName}"
                                            TextColor="{StaticResource BrandTextSecondary}"
                                            VerticalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource BrandTextPrimary}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border
                                            Grid.Column="2"
                                            BackgroundColor="{StaticResource BrandPrimary}"
                                            HeightRequest="7"
                                            IsVisible="{Binding IsSelected}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            VerticalOptions="Center"
                                            WidthRequest="7" />
                                    </Grid>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectLanguageCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label
                            FontSize="16"
                            Text="◔"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                        <Label
                            Grid.Column="1"
                            CharacterSpacing="1.3"
                            FontFamily="OpenSansSemibold"
                            FontSize="13"
                            Text="{Binding AutoNarrationSectionText}"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                    </Grid>

                    <Border
                        Padding="16"
                        BackgroundColor="White"
                        Stroke="{StaticResource BrandStroke}"
                        StrokeShape="RoundRectangle 15">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource BrandShadow}" Offset="0,5" Radius="16" Opacity="0.08" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="15"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding AutoNarrationTitleText}"
                                    TextColor="{StaticResource BrandTextPrimary}" />
                                <Label
                                    FontSize="12"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding AutoNarrationDescriptionText}"
                                    TextColor="{StaticResource BrandTextSecondary}" />
                            </VerticalStackLayout>
                            <Switch
                                Grid.Column="1"
                                HorizontalOptions="End"
                                IsToggled="{Binding IsAutoNarrationEnabled, Mode=TwoWay}"
                                OnColor="{StaticResource BrandPrimary}"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label
                            FontSize="16"
                            Text="□"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                        <Label
                            Grid.Column="1"
                            CharacterSpacing="1.3"
                            FontFamily="OpenSansSemibold"
                            FontSize="13"
                            Text="{Binding FeedbackSectionText}"
                            TextColor="{StaticResource BrandTextMuted}"
                            VerticalTextAlignment="Center" />
                    </Grid>

                    <Border
                        Padding="18"
                        BackgroundColor="{StaticResource BrandPrimary}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#26F48A22" Offset="0,8" Radius="18" Opacity="0.22" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="10">
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="17"
                                LineBreakMode="WordWrap"
                                Text="{Binding ContactSystemNameText}"
                                TextColor="White" />
                            <Label
                                FontSize="13"
                                LineBreakMode="WordWrap"
                                Text="{Binding ContactInstructionsText}"
                                TextColor="#FFF7EE" />

                            <BoxView
                                Margin="0,6"
                                Color="#4DFFFFFF"
                                HeightRequest="1" />

                            <Grid ColumnDefinitions="86,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="7">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="12"
                                    Text="{Binding ContactPhoneCaptionText}"
                                    TextColor="White" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="13"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding ContactPhoneText}"
                                    TextColor="White" />

                                <Label
                                    Grid.Row="1"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="12"
                                    IsVisible="{Binding HasContactEmail}"
                                    Text="{Binding ContactEmailCaptionText}"
                                    TextColor="White" />
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontSize="13"
                                    IsVisible="{Binding HasContactEmail}"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding ContactEmailText}"
                                    TextColor="White" />

                                <Label
                                    Grid.Row="2"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="12"
                                    IsVisible="{Binding HasContactAddress}"
                                    Text="{Binding ContactAddressCaptionText}"
                                    TextColor="White" />
                                <Label
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    FontSize="13"
                                    IsVisible="{Binding HasContactAddress}"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding ContactAddressText}"
                                    TextColor="White" />

                                <Label
                                    Grid.Row="3"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="12"
                                    IsVisible="{Binding HasContactSupportHours}"
                                    Text="{Binding ContactSupportHoursCaptionText}"
                                    TextColor="White" />
                                <Label
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    FontSize="13"
                                    IsVisible="{Binding HasContactSupportHours}"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding ContactSupportHoursText}"
                                    TextColor="White" />

                                <Label
                                    Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    FontSize="11"
                                    IsVisible="{Binding HasContactUpdatedAt}"
                                    Margin="0,4,0,0"
                                    Text="{Binding ContactUpdatedText}"
                                    TextColor="#FFF7EE" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <controls:AppBottomBar Grid.Row="1" />
    </Grid>
</ContentPage>
