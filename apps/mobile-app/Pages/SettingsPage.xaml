<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.MobileApp.Pages.SettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:VinhKhanh.MobileApp.Controls"
    xmlns:models="clr-namespace:VinhKhanh.MobileApp.Models"
    xmlns:viewModels="clr-namespace:VinhKhanh.MobileApp.ViewModels"
    x:DataType="viewModels:SettingsViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource BrandBackground}">
        <ScrollView>
            <VerticalStackLayout Padding="22,24,22,124" Spacing="18">
                <Label
                    HorizontalTextAlignment="Center"
                    Text="{Binding HeaderTitleText}"
                    Style="{StaticResource ScreenTitleStyle}" />

                <Border
                    Margin="0,8,0,0"
                    Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="18">
                        <Label FontFamily="OpenSansSemibold" FontSize="18" Text="{Binding LanguageTitleText}" />

                        <FlexLayout
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            AlignItems="Stretch"
                            BindableLayout.ItemsSource="{Binding Languages}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:LanguageOption">
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="14,14,14,12"
                                        BackgroundColor="White"
                                        MinimumHeightRequest="84"
                                        Stroke="{StaticResource BrandStrokeStrong}"
                                        StrokeShape="RoundRectangle 16"
                                        FlexLayout.Basis="48%"
                                        FlexLayout.Grow="1">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimaryPale}" />
                                                <Setter Property="Stroke" Value="{StaticResource BrandPrimary}" />
                                                <Setter Property="StrokeThickness" Value="1.6" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsLocked}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#FFF8F1" />
                                                <Setter Property="Stroke" Value="#E8D2A8" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                            <Label
                                                Grid.RowSpan="2"
                                                FontSize="28"
                                                Text="{Binding Flag}"
                                                VerticalOptions="Center" />
                                            <Label
                                                Grid.Column="1"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="14"
                                                LineBreakMode="WordWrap"
                                                MaxLines="2"
                                                Text="{Binding DisplayName}"
                                                VerticalOptions="Center" />
                                            <Border
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Padding="10,4"
                                                BackgroundColor="#FFF1D6"
                                                HorizontalOptions="Start"
                                                IsVisible="{Binding IsPremium}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                                <Label
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="10"
                                                    Text="{Binding Source={x:Reference PageRoot}, Path=BindingContext.PremiumBadgeText}"
                                                    TextColor="#9A5B12" />
                                            </Border>
                                        </Grid>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectLanguageCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <controls:AppBottomBar Grid.Row="1" />
    </Grid>
</ContentPage>
