{
  "name": "vinh-khanh-admin-web-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:admin",
    "dev": "node ./scripts/dev-all.cjs",
    "dev:admin": "node ./scripts/run-admin-script.cjs dev",
    "dev:all": "node ./scripts/dev-all.cjs --with-mobile",
    "dev:backend": "node ./scripts/run-backend.cjs dev",
    "serve:backend": "node ./scripts/run-backend.cjs serve",
    "dev:mobile:android": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-mobile-android.ps1",
    "configure:mobile-api": "node ./scripts/configure-mobile-api.cjs",
    "open:android:devices": "powershell -ExecutionPolicy Bypass -File ./scripts/open-android-device-manager.ps1",
    "build": "node ./scripts/run-admin-script.cjs build",
    "build:admin": "node ./scripts/run-admin-script.cjs build",
    "build:backend": "node ./scripts/run-backend.cjs build",
    "preview": "node ./scripts/run-admin-script.cjs preview",
    "lint": "node ./scripts/run-admin-script.cjs lint",
    "install:admin": "node -r ./scripts/npm-dns-override.cjs ./scripts/install-admin.cjs"
  }
}
